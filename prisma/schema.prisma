generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MiscEarningSource {
  manual
  q1_adjustment
}

enum CurrencyCode {
  CHF
  EUR
  MXN
}

model Student {
  id         String    @id @default(cuid())
  name       String    @unique
  subject    String
  ratePerMin Float
  currency   String    @default("CHF")
  email      String?
  active     Boolean   @default(true)
  sessions       Session[]
  invoices       Invoice[]
  subscriptions  PlatformSubscription[]
  createdAt      DateTime  @default(now())

  @@index([active, name])
}

model Session {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  date        DateTime
  durationMin Int
  amountCHF   Float
  calEventId  String?  @unique
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime @default(now())

  @@index([year, month, date])
  @@index([studentId, year, month])
}

model Invoice {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  month         Int
  year          Int
  totalCHF      Float
  sessionIds    String
  invoiceNumber String    @default("")
  sentAt        DateTime?
  reminderSentAt DateTime?
  paidAt        DateTime?
  pdfPath       String?
  createdAt     DateTime  @default(now())

  @@unique([studentId, month, year])
  @@index([year, month, createdAt])
  @@index([studentId, year, month])
}

model TutorProfile {
  id        String   @id @default("default")
  name      String   @default("Max Mustermann")
  email     String   @default("max@example.ch")
  address   String   @default("Musterstrasse 1, 8000 Zürich")
  phone     String   @default("+41 79 000 00 00")
  iban      String   @default("CH00 0000 0000 0000 0000 0")
  bankName  String   @default("Zürcher Kantonalbank")
  /// Jahr für manuelle Q1-Summen (Jan.–Mär.); nur für dieses Jahr
  manualQ1Year   Int?
  /// CHF; wenn alle drei null, gelten die Defaults aus lib/manual-revenue
  manualQ1M1Chf  Float?
  manualQ1M2Chf  Float?
  manualQ1M3Chf  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSubscription {
  id             String           @id @default(cuid())
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  amountCHF      Float
  billingMethod  String           // "invoice" | "direct"
  durationMonths Int              // 1 or 6
  startMonth     Int              // 1–12
  startYear      Int
  active         Boolean          @default(true)
  charges        PlatformCharge[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([studentId, createdAt])
  @@index([active, createdAt])
}

model PlatformCharge {
  id             String               @id @default(cuid())
  subscriptionId String
  subscription   PlatformSubscription @relation(fields: [subscriptionId], references: [id])
  month          Int
  year           Int
  amountCHF      Float
  paidAt         DateTime?
  createdAt      DateTime             @default(now())

  @@unique([subscriptionId, month, year])
}

model MiscEarning {
  id        String            @id @default(cuid())
  year      Int
  month     Int
  amountCHF Float
  label     String?
  source    MiscEarningSource @default(manual)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([year, month, source])
}

model Tutor24Contact {
  id         String   @id @default(cuid())
  tutor24Id  String   @unique
  name       String
  profileUrl String?
  messagedAt DateTime @default(now())
}

model FxRateSnapshot {
  id         String   @id @default("default")
  chfPerEur  Float
  chfPerMxn  Float
  source     String?
  fetchedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DanceEarning {
  id             String       @id @default(cuid())
  date           DateTime
  payerName      String
  amountOriginal Float
  currency       CurrencyCode
  chfRate        Float
  amountCHF      Float
  year           Int
  month          Int
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([year, month, date])
}
